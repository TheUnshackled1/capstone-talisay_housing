{% comment %}
Modern Dashboard for Second Member (Lourynie Joie V. Tingson)
Adapted from Housing Services System UI Design
Responsibilities: M2 (notices, electricity), M3 (docs), M4 (compliance), M6 (reports)
{% endcomment %}

<!-- KPI Cards Grid -->
<div class="modern-grid">
    <!-- Total Applicants Card -->
    <div class="kpi-card">
        <div class="kpi-icon bg-blue">
            <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
        </div>
        <div class="kpi-content">
            <p class="kpi-label">Total Applicants</p>
            <p class="kpi-value">{{ total_applicants|default:0 }}</p>
            <p class="kpi-sub">Across all channels</p>
        </div>
    </div>

    <!-- Pending Notices Card -->
    <div class="kpi-card kpi-warning">
        <div class="kpi-icon bg-amber">
            <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
            </svg>
        </div>
        <div class="kpi-content">
            <p class="kpi-label">Pending Notices</p>
            <p class="kpi-value">{{ pending_notices|default:0 }}</p>
            <p class="kpi-sub">To prepare & issue</p>
        </div>
        {% if pending_notices > 0 %}
        <svg class="kpi-alert" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        {% endif %}
    </div>

    <!-- Electricity Pending Card -->
    <div class="kpi-card">
        <div class="kpi-icon bg-purple">
            <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
        </div>
        <div class="kpi-content">
            <p class="kpi-label">Electricity Pending</p>
            <p class="kpi-value">{{ electricity_pending|default:0 }}</p>
            <p class="kpi-sub">Connection tracking</p>
        </div>
    </div>

    <!-- Incomplete Documents Card -->
    <div class="kpi-card">
        <div class="kpi-icon bg-teal">
            <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
            </svg>
        </div>
        <div class="kpi-content">
            <p class="kpi-label">Incomplete Docs</p>
            <p class="kpi-value">{{ incomplete_docs|default:0 }}</p>
            <p class="kpi-sub">Oversight alerts</p>
        </div>
    </div>
</div>

<!-- Main Widgets Grid -->
<div class="widgets-grid">
    <!-- Priority Tasks Widget -->
    <div class="modern-card">
        <div class="card-head">
            <div class="card-head-left">
                <svg class="icon-sm text-amber" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                <h3>Priority Tasks</h3>
            </div>
            <span class="count-badge bg-amber">{{ pending_notices|default:0 }}</span>
        </div>
        <div class="card-content">
            {% if notices_to_prepare %}
                <div class="task-grid">
                    {% for notice in notices_to_prepare %}
                    <div class="task-row">
                        <div class="task-icon-sm bg-amber">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                            </svg>
                        </div>
                        <div class="task-info">
                            <p class="task-name">{{ notice.type_display }}</p>
                            <p class="task-detail">Block {{ notice.block }}, Lot {{ notice.lot }} • {{ notice.beneficiary_name }}</p>
                        </div>
                        <button class="btn-action">Prepare</button>
                    </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="empty-modern">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                    <p>All notices up to date</p>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Electricity Connections Widget -->
    <div class="modern-card">
        <div class="card-head">
            <div class="card-head-left">
                <svg class="icon-sm text-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
                <h3>Electricity Connections</h3>
            </div>
            <span class="count-badge bg-purple">{{ electricity_pending|default:0 }}</span>
        </div>
        <div class="card-content">
            {% if electricity_tracking %}
                <div class="progress-grid">
                    {% for item in electricity_tracking %}
                    <div class="progress-card">
                        <div class="progress-top">
                            <span class="progress-label">Block {{ item.block }}, Lot {{ item.lot }}</span>
                            <span class="status-badge status-{{ item.status }}">{{ item.status_display }}</span>
                        </div>
                        <div class="progress-track">
                            <div class="progress-outer">
                                <div class="progress-inner" style="width: {{ item.progress }}%"></div>
                            </div>
                            <span class="progress-num">{{ item.progress }}%</span>
                        </div>
                        <p class="progress-info">{{ item.beneficiary_name }} • {{ item.last_updated }}</p>
                    </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="empty-modern">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                    </svg>
                    <p>No pending connections</p>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Document Oversight Widget -->
    <div class="modern-card">
        <div class="card-head">
            <div class="card-head-left">
                <svg class="icon-sm text-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                </svg>
                <h3>Document Oversight</h3>
            </div>
            <span class="count-badge bg-teal">{{ incomplete_docs|default:0 }}</span>
        </div>
        <div class="card-content">
            {% if doc_completeness_alerts %}
                <div class="task-grid">
                    {% for alert in doc_completeness_alerts %}
                    <div class="alert-row">
                        <div class="alert-circle">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12.01" y2="8"/><line x1="12" y1="12" x2="12" y2="16"/>
                            </svg>
                        </div>
                        <div class="alert-data">
                            <p class="alert-person">{{ alert.applicant_name }} <span class="text-muted">({{ alert.reference }})</span></p>
                            <p class="alert-msg">Missing: {{ alert.missing_docs }}</p>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="empty-modern">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                    <p>All documents complete</p>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Upcoming Reports Widget -->
    <div class="modern-card">
        <div class="card-head">
            <div class="card-head-left">
                <svg class="icon-sm text-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
                <h3>Upcoming Reports</h3>
            </div>
        </div>
        <div class="card-content">
            {% if reports_to_generate %}
                <div class="task-grid">
                    {% for report in reports_to_generate %}
                    <div class="task-row">
                        <div class="task-icon-sm bg-blue">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                            </svg>
                        </div>
                        <div class="task-info">
                            <p class="task-name">{{ report.title }}</p>
                            <p class="task-detail">Due: {{ report.due_date }}</p>
                        </div>
                        <button class="btn-action">Generate</button>
                    </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="empty-modern">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                    </svg>
                    <p>No reports due</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<style>
/* Modern UI Styles for Second Member Dashboard */
.modern-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.kpi-card {
    background: white;
    border-radius: 0.75rem;
    border: 1px solid #e2e8f0;
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    padding: 1rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    transition: box-shadow 0.15s;
}

.kpi-card:hover {
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
}

.kpi-card.kpi-warning {
    border-color: #fde68a;
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05), 0 0 0 1px #fef3c7;
}

.kpi-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.kpi-icon.bg-blue { background: #dbeafe; }
.kpi-icon.bg-amber { background: #fef3c7; }
.kpi-icon.bg-purple { background: #f3e8ff; }
.kpi-icon.bg-teal { background: #ccfbf1; }

.kpi-icon svg { width: 1.25rem; height: 1.25rem; }
.kpi-icon.bg-blue svg { color: #2563eb; }
.kpi-icon.bg-amber svg { color: #b45309; }
.kpi-icon.bg-purple svg { color: #9333ea; }
.kpi-icon.bg-teal svg { color: #0d9488; }

.kpi-content {
    flex: 1;
    min-width: 0;
}

.kpi-label {
    font-size: 11px;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.025em;
    line-height: 1;
    margin: 0;
}

.kpi-value {
    font-size: 1.5rem;
    font-weight: 500;
    color: #0f172a;
    margin: 0.25rem 0 0 0;
}

.kpi-sub {
    font-size: 11px;
    color: #64748b;
    margin: 0.125rem 0 0 0;
}

.kpi-alert {
    width: 1rem;
    height: 1rem;
    color: #f59e0b;
    flex-shrink: 0;
    margin-top: 0.125rem;
}

.widgets-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(480px, 1fr));
    gap: 1rem;
}

@media (max-width: 1024px) {
    .widgets-grid {
        grid-template-columns: 1fr;
    }
}

.modern-card {
    background: white;
    border-radius: 0.75rem;
    border: 1px solid #e2e8f0;
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
}

.card-head {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e2e8f0;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.card-head-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.card-head h3 {
    font-size: 0.875rem;
    font-weight: 500;
    color: #1e293b;
    margin: 0;
}

.icon-sm {
    width: 1rem;
    height: 1rem;
}

.text-amber { color: #d97706; }
.text-purple { color: #9333ea; }
.text-teal { color: #0d9488; }
.text-blue { color: #2563eb; }

.count-badge {
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
}

.count-badge.bg-amber { background: #fef3c7; color: #b45309; }
.count-badge.bg-purple { background: #f3e8ff; color: #7e22ce; }
.count-badge.bg-teal { background: #ccfbf1; color: #0f766e; }
.count-badge.bg-blue { background: #dbeafe; color: #1d4ed8; }

.card-content {
    padding: 1rem;
}

.task-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.task-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid #f1f5f9;
    transition: background 0.15s;
}

.task-row:hover {
    background: #f8fafc;
}

.task-icon-sm {
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-center;
    flex-shrink: 0;
}

.task-icon-sm.bg-amber { background: #fef3c7; }
.task-icon-sm.bg-blue { background: #dbeafe; }

.task-icon-sm svg {
    width: 1rem;
    height: 1rem;
}

.task-icon-sm.bg-amber svg { color: #d97706; }
.task-icon-sm.bg-blue svg { color: #2563eb; }

.task-info {
    flex: 1;
    min-width: 0;
}

.task-name {
    font-size: 0.75rem;
    font-weight: 500;
    color: #334155;
    margin: 0;
}

.task-detail {
    font-size: 11px;
    color: #64748b;
    margin: 0;
}

.btn-action {
    padding: 0.375rem 0.75rem;
    background: #1d4ed8;
    color: white;
    font-size: 0.75rem;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: background 0.15s;
}

.btn-action:hover {
    background: #1e40af;
}

.progress-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.progress-card {
    padding: 0.75rem;
    border-radius: 0.5rem;
    background: #f8fafc;
    border: 1px solid #f1f5f9;
}

.progress-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
}

.progress-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: #334155;
}

.status-badge {
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    font-size: 10px;
    font-weight: 500;
}

.status-badge.status-pending { background: #fef3c7; color: #b45309; }
.status-badge.status-in_progress { background: #dbeafe; color: #1d4ed8; }
.status-badge.status-completed { background: #dcfce7; color: #15803d; }

.progress-track {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
}

.progress-outer {
    flex: 1;
    height: 0.5rem;
    background: #e2e8f0;
    border-radius: 9999px;
    overflow: hidden;
}

.progress-inner {
    height: 100%;
    background: linear-gradient(90deg, #2563eb, #9333ea);
    border-radius: 9999px;
    transition: width 0.3s;
}

.progress-num {
    font-size: 10px;
    font-weight: 500;
    color: #475569;
    min-width: 35px;
    text-align: right;
}

.progress-info {
    font-size: 11px;
    color: #64748b;
    margin: 0;
}

.alert-row {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid #f1f5f9;
    transition: background 0.15s;
}

.alert-row:hover {
    background: #f8fafc;
}

.alert-circle {
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    background: #fef3c7;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.alert-circle svg {
    width: 1rem;
    height: 1rem;
    color: #d97706;
}

.alert-data {
    flex: 1;
    min-width: 0;
}

.alert-person {
    font-size: 0.75rem;
    font-weight: 500;
    color: #334155;
    margin: 0;
}

.text-muted {
    color: #64748b;
}

.alert-msg {
    font-size: 11px;
    color: #b45309;
    margin: 0;
}

.empty-modern {
    text-align: center;
    padding: 2rem;
}

.empty-modern svg {
    width: 3rem;
    height: 3rem;
    color: #cbd5e1;
    margin: 0 auto 0.75rem;
}

.empty-modern p {
    font-size: 0.875rem;
    color: #64748b;
    margin: 0;
}
</style>
