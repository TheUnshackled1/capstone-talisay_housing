# Copy this to .env and fill in your actual values
SMS_ENABLED=True

# Use "console" for local testing (prints SMS content in runserver terminal).
# Use "iprog" for live sending once IPROG_API_TOKEN is set.
SMS_SERVICE=console

# Live gateway token (required only when SMS_SERVICE=iprog)
IPROG_API_TOKEN=your_iprog_api_token_here

# Optional reliability tuning for slower provider responses
IPROG_SEND_TIMEOUT_SECONDS=25
IPROG_STATUS_TIMEOUT_SECONDS=12
IPROG_SEND_RETRY_ATTEMPTS=3
IPROG_SEND_RETRY_BACKOFF_SECONDS=1.5
